FLASK_ENV=development
DEBUG=true
SECRET_KEY=change-me
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/career_match
MAX_CONTENT_LENGTH_MB=5
TINYFISH_API_KEY=replace-with-your-tinyfish-api-key
TINYFISH_BASE_URL=https://agent.tinyfish.ai
TINYFISH_API_TIMEOUT_SECONDS=60
TINYFISH_DEFAULT_BROWSER_PROFILE=lite
TINYFISH_DEFAULT_PROXY_ENABLED=false
TINYFISH_DEFAULT_PROXY_COUNTRY_CODE=US
